# default: everything is LF
* text=auto eol=lf

# shell scripts (must be LF)
*.sh text eol=lf

# config / markdown / agents
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# LaTeX / CSV / HTML
*.tex text eol=lf
*.csv text eol=lf
*.html text eol=lf

# Windows-only (if ever needed)
*.ps1 text eol=crlf
*.bat  text eol=crlf

