# .gitignore.research
# Datasets / large external artifacts
data/raw/
data/external/
data/**/.DS_Store

# Checkpoints (usually too large for git)
checkpoints/
weights/

# Apptainer/Singularity containers
*.sif

# Experiment outputs (keep config/run scripts, ignore bulky outputs)
experiments/**/logs/
experiments/**/artifacts/
experiments/**/results/

# Python
__pycache__/
*.pyc
.venv/
venv/
.env
