# Remote execution settings for remote.sh

# Connection
REMOTE_HOST=ohki_highgarden
REMOTE_BASE=hsdisk
REMOTE_PROJECT=Saliuitl
# REMOTE_DIR_OVERRIDE=          # Absolute path (overrides BASE/PROJECT)
# REMOTE_SSH_OPTS="-o ConnectTimeout=10"

# Apptainer
APPTAINER_SIF=saliuitl.sif
# APPTAINER_BIND="/data:/data,/scratch:/scratch"  # bind paths (host:container)
APPTAINER_BIND="/nvme1/home/hoshino/Saliuitl_dev"
# APPTAINER_OPTS="--nv"                            # additional options (--nv for GPU)

# Policy
REMOTE_LOCK=1                   # Lock GPU runs (prevent concurrent)
REMOTE_REQUIRE_TMUX=0           # Require tmux (fail if unavailable)

# Git
REMOTE_GIT_URL=https://github.com/KOUTYA47/Saliuitl.git
REMOTE_GIT_BRANCH=main

# SIF file location (for systems where SIF is stored separately)
# Set this if SIF files are in a shared/external location
# REMOTE_SIF_DIR=/shared/containers
